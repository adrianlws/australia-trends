# scripts/02_fetch_google.R
library(httr2)
library(xml2)
library(dplyr)
library(readr)
library(stringr)
library(lubridate)
library(janitor)
fetch_google_trends_au <- function() {
rss_url <- "https://trends.google.com/trending/rss?geo=AU"
resp <- request(rss_url) |>
req_perform()
xml_text <- resp_body_string(resp)
doc <- read_xml(xml_text)
items <- xml_find_all(doc, ".//item")
if (length(items) == 0) {
stop("No Google Trends items found.")
}
tibble(
source = "google_trends",
platform = "google",
topic = xml_text(xml_find_first(items, "./title")),
pub_date_raw = xml_text(xml_find_first(items, "./pubDate")),
link = xml_text(xml_find_first(items, "./link")),
description = xml_text(xml_find_first(items, "./description"))
) |>
clean_names() |>
mutate(
fetch_date = as.Date(Sys.time(), tz = "Australia/Sydney"),
fetched_at = with_tz(Sys.time(), tzone = "Australia/Sydney"),
pub_date = suppressWarnings(parse_date_time(pub_date_raw, orders = c("a, d b Y H:M:S z", "d b Y H:M:S z")))
) |>
select(fetch_date, fetched_at, source, platform, topic, pub_date, link, description)
}
google_df <- fetch_google_trends_au()
out_file <- file.path(
"data", "raw", "google",
paste0("google_trends_", Sys.Date(), ".csv")
)
write_csv(google_df, out_file)
message("Saved Google Trends data to: ", out_file)
print(google_df)
# scripts/03_fetch_reddit.R
library(httr2)
library(jsonlite)
library(dplyr)
library(readr)
library(purrr)
library(stringr)
library(lubridate)
library(janitor)
subreddits <- read_csv("config/subreddits.csv", show_col_types = FALSE) |>
filter(enabled)
fetch_subreddit_hot <- function(subreddit, limit = 25) {
url <- paste0("https://www.reddit.com/r/", subreddit, "/hot.json?limit=", limit)
resp <- request(url) |>
req_user_agent("australia-trends-hobby-project/0.1") |>
req_perform()
txt <- resp_body_string(resp)
json <- fromJSON(txt, flatten = TRUE)
posts <- json$data$children$data
if (length(posts) == 0 || nrow(posts) == 0) {
return(tibble())
}
tibble(
fetch_date = as.Date(Sys.time(), tz = "Australia/Sydney"),
fetched_at = with_tz(Sys.time(), tzone = "Australia/Sydney"),
source = "reddit",
platform = "reddit",
subreddit = subreddit,
post_id = posts$id,
title = posts$title,
score = posts$score,
num_comments = posts$num_comments,
created_utc = as_datetime(posts$created_utc, tz = "UTC"),
url = ifelse(
str_detect(posts$url, "^http"),
posts$url,
paste0("https://www.reddit.com", posts$permalink)
),
over_18 = posts$over_18,
is_self = posts$is_self
)
}
reddit_df <- map_dfr(subreddits$subreddit, fetch_subreddit_hot)
out_file <- file.path(
"data", "raw", "reddit",
paste0("reddit_hot_", Sys.Date(), ".csv")
)
write_csv(reddit_df, out_file)
message("Saved Reddit data to: ", out_file)
print(reddit_df)
